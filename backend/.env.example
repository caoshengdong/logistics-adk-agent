# ── Google Gemini ─────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=your-google-api-key

# ── Logistics Provider ───────────────────────────────────────────────
LOGISTICS_PROVIDER_BACKEND=mock
# Only required when LOGISTICS_PROVIDER_BACKEND=http
LOGISTICS_API_BASE_URL=http://47.115.60.18
LOGISTICS_AUTH_CODE=your-client-code
LOGISTICS_AUTH_TOKEN=your-api-token
LOGISTICS_HTTP_TIMEOUT_SECONDS=10

# ── Database (PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/logistics-agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=logistics-agent

# ── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# ── CORS (backend) ──────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend.
# In production on Render, set to your frontend's public URL.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
